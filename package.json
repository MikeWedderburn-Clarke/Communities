{
  "name": "communities",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:seed": "npx tsx src/db/seed.ts",
    "db:dump": "docker exec communities-db pg_dump -U postgres -Fc communities > backup.dump",
    "db:restore": "docker exec -i communities-db pg_restore -U postgres -d communities --clean --if-exists < backup.dump"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "drizzle-orm": "^0.38.0",
    "leaflet": "^1.9.4",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
