# ── Database ─────────────────────────────────────────────────────────
# Local dev — matches the docker-compose.yml defaults:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/communities

# Test database — separate DB on the same server, seeded with rich test data.
# Run: npm run db:migrate-test && npm run db:seed-test
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/communities_test

# Azure Postgres — used by db:push-azure to sync local data to production.
# Leave commented out unless you are doing a manual data sync.
# AZURE_DATABASE_URL=postgres://user:password@your-server.postgres.database.azure.com:5432/communities?sslmode=require

# ── NextAuth.js ──────────────────────────────────────────────────────
# Random secret for signing JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret

# ── Mock auth (local development only) ──────────────────────────────
# Set to "true" to enable the dev user-picker login page.
# Leave unset (or set to "false") in production.
MOCK_AUTH=true

# ── Microsoft Entra External ID (production) ─────────────────────────
# Leave unset when MOCK_AUTH=true.
# AUTH_ENTRA_CLIENT_ID=<Application (client) ID from Azure portal>
# AUTH_ENTRA_CLIENT_SECRET=<Client secret value>
# AUTH_ENTRA_ISSUER=https://<tenant>.ciamlogin.com/<tenant-id>/v2.0
